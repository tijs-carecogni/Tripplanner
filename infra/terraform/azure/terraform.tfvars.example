# Set create_resource_group = false if the group already exists (empty RG in portal).
create_resource_group = true
resource_group_name   = "tripmind-demo-rg"
location              = "westeurope"

container_app_name         = "tripmind-demo"
container_environment_name = "tripmind-demo-env"

# Create ACR in the same RG, or set create_acr = false and point at an existing registry.
create_acr = true
acr_name   = "youruniqueregistryname" # globally unique, alphanumeric only, 5-50 chars

# First apply: use a public placeholder so the app can pull; push your image, then apply again.
# Example after CI push: "<acr_name>.azurecr.io/tripplanner:latest"
container_image = "docker.io/library/nginx:alpine"

# create_acr = false
# acr_name = "myexistingacr"
# acr_resource_group_name = "" # or another RG name if ACR is elsewhere
